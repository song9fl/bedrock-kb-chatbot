AWS_REGION=us-east-1
APP_ENV=production
BEDROCK_KB_ID=YOUR_KNOWLEDGE_BASE_ID
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1:YOUR_ACCOUNT_ID:inference-profile/us.meta.llama4-maverick-17b-instruct-v1:0
BEDROCK_NUMBER_OF_RESULTS=5
BEDROCK_SEARCH_TYPE=DEFAULT
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.2
BEDROCK_TOP_P=0.9
BEDROCK_QUERY_DECOMPOSITION=false
CHAT_HISTORY_MODE=aws
CHAT_HISTORY_DYNAMODB_TABLE=bedrock-kb-chatbot-history
CHAT_HISTORY_S3_BUCKET=YOUR_GLOBALLY_UNIQUE_CHAT_HISTORY_BUCKET
